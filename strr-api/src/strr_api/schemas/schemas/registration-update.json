{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://strr.gov.bc.ca/.well_known/schemas/registration_update",
  "type": "object",
  "title": "Registration Update",
  "description": "Schema for updating registration details. Supports partial updates to nested registration fields.",
  "properties": {
    "primaryContact": {
      "type": "object",
      "properties": {
        "emailAddress": {
          "type": "string",
          "format": "email"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "minProperties": 1
}
