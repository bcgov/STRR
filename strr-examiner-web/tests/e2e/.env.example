# Playwright e2e only — copy to `tests/e2e/.env` and fill in (gitignored).
# Root `.env` is still loaded first for NUXT_BASE_URL and Nuxt; values here override.
# BCeID global setup uses `/en-CA/auth/login?idp=bceid` (IdP must be listed in app `idps`).

# global-setup writes tests/e2e/.auth/*.json (gitignored)
# unset, empty, or idir => IDIR login + idir-user.json
# bceid => BCeID login + TOTP flow + bceid-user.json
PLAYWRIGHT_E2E_LOGIN=

PLAYWRIGHT_TEST_USERNAME=
PLAYWRIGHT_TEST_PASSWORD=

PLAYWRIGHT_TEST_BCEID_USERNAME=
PLAYWRIGHT_TEST_BCEID_PASSWORD=
# Base32 TOTP secret for the BCeID test account (required when PLAYWRIGHT_E2E_LOGIN=bceid)
PLAYWRIGHT_TEST_BCEID_OTP_SECRET=

# Set to true to flow through the TOTP flow
# PLAYWRIGHT_TEST_BCEID_TOTP_FLOW=true

# Playwright video: on | off | retain-on-failure | on-first-retry
# PLAYWRIGHT_VIDEO=on

